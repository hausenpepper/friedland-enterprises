    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm">
        &copy; {currentYear} Friedland Enterprises. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="#about" class="text-sm hover:text-brand-white transition-colors">About</a>
        <a href="#contact" class="text-sm hover:text-brand-white transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>
