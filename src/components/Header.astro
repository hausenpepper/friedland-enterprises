---
const navLinks = [
  { label: "About", href: "#about" },
  { label: "Focus", href: "#focus" },
  { label: "Contact", href: "#contact" },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo / Wordmark -->
    <a href="/" class="text-lg font-semibold tracking-tight text-brand-navy">
      Friedland Enterprises
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-brand-steel hover:text-brand-navy transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Open menu"
    >
      <span class="block w-6 h-0.5 bg-brand-navy transition-all duration-300" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-brand-navy transition-all duration-300" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-brand-navy transition-all duration-300" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 bg-brand-white z-40 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300"
  >
    <button
      id="mobile-menu-close"
      class="absolute top-6 right-6 p-2 text-brand-navy"
      aria-label="Close menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="mobile-nav-link text-2xl font-semibold text-brand-navy hover:text-brand-accent transition-colors"
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<script>
  const header = document.getElementById("site-header")!;
  const menuBtn = document.getElementById("mobile-menu-btn")!;
  const menuClose = document.getElementById("mobile-menu-close")!;
  const menu = document.getElementById("mobile-menu")!;

  // Frosted glass on scroll
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header.classList.add("bg-brand-white/90", "backdrop-blur-md", "shadow-sm");
    } else {
      header.classList.remove("bg-brand-white/90", "backdrop-blur-md", "shadow-sm");
    }
  });

  // Mobile menu toggle
  menuBtn.addEventListener("click", () => {
    menu.classList.remove("opacity-0", "pointer-events-none");
    menu.classList.add("opacity-100", "pointer-events-auto");
  });

  const closeMenu = () => {
    menu.classList.add("opacity-0", "pointer-events-none");
    menu.classList.remove("opacity-100", "pointer-events-auto");
  };

  menuClose.addEventListener("click", closeMenu);
  menu.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });
</script>
